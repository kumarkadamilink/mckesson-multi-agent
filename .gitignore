# ──────────────────────────────────────────────
# McKesson Multi-Agent Procurement — .gitignore
# ──────────────────────────────────────────────

# Azure Developer CLI — contains subscription IDs, env secrets
.azure/

# Environment variables — API keys, connection strings
.env
.env.*
*.env

# ChromaDB local index — regenerated by running index_documents.py
data/chroma_db/

# Fastembed / ONNX model cache — downloaded automatically on first run
.cache/
~/.cache/fastembed/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env/

# VS Code
.vscode/
*.code-workspace

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker
*.tar

# Infra generated files — safe to exclude, regenerated by azd
# infra/   ← keep this commented; infra should be committed
